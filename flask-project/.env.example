SECRET_KEY=your-secret-key-here

# Twilio SMS credentials — get these from twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Scheduler time (24-hour format). Default: 8 AM daily
ALERT_HOUR=8
ALERT_MINUTE=0

# Optional: Agmarknet live data API key (data.gov.in)
AGMARKNET_API_KEY=
